{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "UTC",
  "enabledManagers": ["bazelisk", "bazel-module", "custom.regex"],
  "regexManagers": [
    {
      "fileMatch": ["^MODULE\\.bazel$"],
      "matchStrings": [
        "crate\\.spec\\(\\s*package\\s*=\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?version\\s*=\\s*\"(?:=)?(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "crates-io",
      "depNameTemplate": "{{{depName}}}",
      "versioningTemplate": "semver"
    }
  ]
}
