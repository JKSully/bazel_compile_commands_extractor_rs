{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": false,
  "timezone": "America/New_York",
  "schedule": ["* 0-9 * * 3"], // every wednesday before 9am
  "enabledManagers": [
    "bazelisk",
    "bazel-module",
    "pre-commit",
    "cargo",
    "github-actions"
  ],
  "bazel-module": {
    "managerFilePatterns": ["/(^MODULE\\.bazel$|^examples/.*MODULE\\.bazel$)/"]
  },
  "pre-commit": {
    "enabled": true
  }
}
