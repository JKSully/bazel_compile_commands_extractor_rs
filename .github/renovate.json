{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "timezone": "UTC",
  "regexManagers": [
    {
      "fileMatch": ["^MODULE\\.bazel$"],
      "matchStrings": [
        "bazel_dep\\(\\s*name\\s*=\\s*\"(?<depName>[^\"]+)\",\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\"\\s*\\)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "bazelbuild/{{{depName}}}",
      "versioningTemplate": "semver"
    },
    {
      "fileMatch": ["^MODULE\\.bazel$"],
      "matchStrings": [
        "crate\\.spec\\(\\s*package\\s*=\\s*\"(?<depName>[^\"]+)\"[\\s\\S]*?version\\s*=\\s*\"(?:=)?(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "crates-io",
      "depNameTemplate": "{{{depName}}}",
      "versioningTemplate": "semver"
    }
  ]
}
